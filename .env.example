# ===== LLM 模型 =====
# 阿里云 DashScope API Key（获取地址：https://dashscope.console.aliyun.com/apiKey）
ARK_API_KEY=your_dashscope_api_key_here
MODEL=qwen3-max
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GRADE_MODEL=qwen3.6-flash
# 快速模型（用于会话标题生成、持久化笔记、复杂度分类）
FAST_MODEL=qwen3.6-flash

# ===== 本地向量模型 =====
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
DENSE_EMBEDDING_DIM=1024

# ===== 重排序（可选）=====
# Jina AI API Key（获取地址：https://jina.ai/embeddings/）
RERANK_MODEL=jina-reranker-v3
RERANK_BINDING_HOST=https://api.jina.ai/v1/rerank
RERANK_API_KEY=your_jina_api_key_here

# ===== Milvus 向量数据库 =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_TIMEOUT=30
MILVUS_COLLECTION=embeddings_collection

# ===== 检索配置（可选）=====
# 候选池倍数（候选数 = top_k × 倍数；仅当 RETRIEVAL_CANDIDATE_K 未设置时生效）
RETRIEVAL_CANDIDATE_MULTIPLIER=3
# 候选池显式大小（设置后将忽略倍数，直接使用此值；留空则使用倍数计算）
# RETRIEVAL_CANDIDATE_K=
# 自动合并开关（true/false，将叶子块合并为父块）
AUTO_MERGE_ENABLED=true
# 自动合并阈值（同一父块下至少 N 个子块被召回才触发合并）
AUTO_MERGE_THRESHOLD=2
# 重排序最低分阈值（低于此分数的文档会被过滤）
RERANK_MIN_SCORE=0.0
# 叶节点检索层级（默认 3，即最细粒度）
LEAF_RETRIEVE_LEVEL=3
# HuggingFace 镜像端点（可选，国内加速）
# HF_ENDPOINT=https://hf-mirror.com

# ===== 关系型数据库 & 缓存 =====
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/langchain_app
REDIS_URL=redis://127.0.0.1:6379/0

# ===== JWT 认证 =====
JWT_SECRET_KEY=change-this-to-a-random-string-at-least-32-chars
ADMIN_INVITE_CODE=your-admin-invite-code
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000

# ===== Tavily 网页搜索（可选）=====
# 获取地址：https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ===== 工具（可选）=====
# 高德天气 API（获取地址：https://lbs.amap.com/）
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=your_amap_api_key_here
